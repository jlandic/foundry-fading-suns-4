<div class="header">
  <div class="block-thick area-identity">
    <!-- Name -->
    <label>{{ localize "FS4.Character.Trait.Name" }}</label>
    <input type="text" name="name" value="{{actor.name}}">

    <!-- Birthdate -->
    <label>{{ localize "FS4.Character.Trait.Birthdate" }}</label>
    <input type="text" name="system.birthdate" value="{{actor.system.birthdate}}">
    
    <label>{{ localize "FS4.Character.Trait.Species" }}</label>
    <input type="text" value="{{actor.system.species.name}}" class="item-show" data-uuid="{{actor.system.species.uuid}}" placeholder="-" readonly>

    <div class="size-speed-level">
      <label>{{ localize "FS4.Character.Trait.Size" }}</label>
      <input type="number" name="system.size" value="{{actor.system.size}}">

      <label>{{ localize "FS4.Character.Trait.Speed" }}</label>
      <input type="text" name="system.speed" value="{{actor.system.speed}}">

      <label>{{ localize "FS4.Character.Trait.Level" }}</label>
      <input type="number" name="system.level" value="{{actor.system.level}}">
    </div>

    <label>{{ localize "FS4.Character.Trait.Affliction" }}</label>
    <input type="text" value="{{actor.system.affliction.name}}" class="item-show" data-uuid="{{actor.system.affliction.uuid}}" placeholder="-" readonly>

    <label>{{ localize "FS4.Character.Trait.Planet" }}</label>
    <input type="text" name="system.planet" value="{{actor.system.planet}}">

    <label>{{ localize "FS4.Character.Trait.Blessing" }}</label>
    <input type="text" value="{{actor.system.blessing.name}}" class="item-show" data-uuid="{{actor.system.blessing.uuid}}" placeholder="-" readonly>

    <label>{{ localize "FS4.Character.Trait.Curse" }}</label>
    <input type="text" value="{{actor.system.curse.name}}" class="item-show" data-uuid="{{actor.system.curse.uuid}}" placeholder="-" readonly>
  </div>

  <div class="area-image">
    <img src="{{actor.img}}" alt="Actor image" data-edit="img" width="128" height="128">
  </div>
</div>
